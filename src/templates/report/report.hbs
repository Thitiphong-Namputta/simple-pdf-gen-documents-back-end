<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <style>
    @font-face {
      font-family: 'Sarabun';
      src: url('/fonts/Sarabun-Regular.ttf') format('truetype');
      font-weight: normal;
    }
    @font-face {
      font-family: 'Sarabun';
      src: url('/fonts/Sarabun-Bold.ttf') format('truetype');
      font-weight: bold;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Sarabun', sans-serif; font-size: 13px; color: #222; background: #fff; }
    .page { padding: 16px 20px; }
    h1 { font-size: 22px; font-weight: bold; color: #1a1a2e; margin-bottom: 4px; }
    .subtitle { font-size: 12px; color: #666; margin-bottom: 20px; }
    .section { margin-bottom: 28px; }
    .section-title { font-size: 15px; font-weight: bold; color: #1a1a2e; border-left: 4px solid #1a1a2e; padding-left: 10px; margin-bottom: 12px; }
    .stats { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 24px; }
    .stat-card { flex: 1; min-width: 120px; background: #f0f2ff; border-radius: 8px; padding: 14px 16px; }
    .stat-label { font-size: 11px; color: #666; }
    .stat-value { font-size: 22px; font-weight: bold; color: #1a1a2e; margin-top: 4px; }
    .stat-unit { font-size: 11px; color: #888; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: #1a1a2e; color: #fff; }
    thead th { padding: 9px 12px; text-align: left; font-size: 12px; }
    tbody tr:nth-child(even) { background: #f7f7fb; }
    tbody td { padding: 8px 12px; border-bottom: 1px solid #eee; font-size: 12px; }
    .chart-placeholder { background: #f7f7fb; border: 1px dashed #ccc; border-radius: 6px; padding: 12px; text-align: center; }
    .chart-placeholder img { max-width: 100%; height: auto; }
    @media print {
      * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .section { page-break-inside: avoid; }
    }
  </style>
</head>
<body>
  <div class="page">
    <h1>{{title}}</h1>
    <div class="subtitle">{{#if period}}ช่วงเวลา: {{period}} • {{/if}}สร้างเมื่อ: {{generatedAt}}</div>

    {{#if summary}}
    <div class="stats">
      {{#each summary}}
      <div class="stat-card">
        <div class="stat-label">{{label}}</div>
        <div class="stat-value">{{value}}</div>
        {{#if unit}}<div class="stat-unit">{{unit}}</div>{{/if}}
      </div>
      {{/each}}
    </div>
    {{/if}}

    {{#if chartImage}}
    <div class="section">
      <div class="section-title">กราฟ</div>
      <div class="chart-placeholder">
        <img src="{{chartImage}}" alt="chart" />
      </div>
    </div>
    {{/if}}

    {{#if tableData}}
    <div class="section">
      <div class="section-title">{{#if tableTitle}}{{tableTitle}}{{else}}ตารางข้อมูล{{/if}}</div>
      <table>
        <thead>
          <tr>
            {{#each tableHeaders}}
            <th>{{this}}</th>
            {{/each}}
          </tr>
        </thead>
        <tbody>
          {{#each tableData}}
          <tr>
            {{#each this}}
            <td>{{this}}</td>
            {{/each}}
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}

    {{#if notes}}
    <div class="section">
      <div class="section-title">หมายเหตุ</div>
      <p style="font-size:12px;color:#444;line-height:1.8;">{{notes}}</p>
    </div>
    {{/if}}
  </div>
</body>
</html>
