generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model DocumentRecord {
  id        String   @id @default(cuid())
  type      String
  format    String   @default("pdf")
  filename  String
  summary   String
  createdAt DateTime @default(now())
}

model ImportRecord {
  id        String   @id @default(cuid())
  type      String
  payload   String   // JSON string of the imported row
  createdAt DateTime @default(now())
}
